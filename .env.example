# Copy this file to .env and set paths to your local media directories.
# These folders are bind-mounted into the container and scanned on load.

# Required
COMIC_PATH=/path/to/your/comics
VIDEO_PATH=/path/to/your/videos

# Optional – defaults to a temporary directory if not set
IMAGE_PATH=/path/to/your/images

# Override scan paths inside the container (rarely needed)
# COMIC_SCAN_PATH=/data/comics
# VIDEO_SCAN_PATH=/data/videos
